# ──────────────────────────────────────────────────────────────────
#  Hedera Options Vault — Environment Configuration
#  Copy this file to .env and fill in your values.
# ──────────────────────────────────────────────────────────────────

# ── Hedera Operator (your account that signs + pays for transactions)
OPERATOR_ACCOUNT_ID=0.0.XXXXXX
OPERATOR_PRIVATE_KEY=0x...your_ECDSA_or_ED25519_key...

# Testnet operator (can be the same or different)
TESTNET_OPERATOR_ACCOUNT_ID=0.0.XXXXXX
TESTNET_OPERATOR_PRIVATE_KEY=0x...

# ── Hedera Network Config
HEDERA_NETWORK=testnet                          # testnet | mainnet | local
HEDERA_TESTNET_RPC=https://testnet.hashio.io/api
HEDERA_MAINNET_RPC=https://mainnet.hashio.io/api
HEDERA_MIRROR_NODE=https://testnet.mirrornode.hedera.com

# ── Deployed Contract Addresses (filled after deployment)
OPTIONS_VAULT_ADDRESS=0x...
OPTION_TOKEN_ADDRESS=0x...

# ── Pyth Oracle
# Hermes endpoint for fetching signed price update data
PYTH_HERMES_ENDPOINT=https://hermes.pyth.network
# Pyth contract address on Hedera testnet
PYTH_CONTRACT_ADDRESS=0xA2aa501b19aff244D90cc15a4Cf739D2725B5729

# ── Claude AI (for the Agent)
ANTHROPIC_API_KEY=sk-ant-...

# ── Collateral Token Addresses (on Hedera testnet)
# USDC — bridged from Ethereum via Hashport
USDC_ADDRESS=0x...
# Wyoming FRNT stablecoin (when live on testnet)
FRNT_ADDRESS=0x...

# ── Options Defaults
DEFAULT_RISK_FREE_RATE=50000000000000000      # 5% in WAD (1e18 = 100%)
DEFAULT_VOLATILITY=800000000000000000          # 80% in WAD
DEFAULT_EXPIRY_DURATION_DAYS=7

# ── Gas / Reporting
REPORT_GAS=true